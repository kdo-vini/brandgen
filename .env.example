# ─── AI ──────────────────────────────────────────────────────────────────────
# Google Gemini API key (server-side only — NEVER expose to frontend)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Public URL (safe to expose to frontend via VITE_ prefix)
VITE_SUPABASE_URL=https://your-project.supabase.co
# Anon/public key (safe to expose to frontend)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Service role key (server-side only — bypasses RLS — NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Secret key (server-side only — NEVER expose to frontend)
STRIPE_SECRET_KEY=sk_live_or_sk_test_...
# Webhook signing secret (from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for the Social Media Pro plan (from Stripe Dashboard > Products)
STRIPE_PRO_PRICE_ID=price_...

# ─── App ──────────────────────────────────────────────────────────────────────
# Your production URL (used for Stripe checkout success/cancel redirects)
APP_URL=https://your-app.vercel.app
